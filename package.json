    "test": "echo \"Error: no test specified\" && exit 1",
    "build:gallery": "node gallery/build.js",
    "capture:thumbnails": "node gallery/capture-screenshots.js",
    "benchmark:static-world": "tsx tools/benchmark/run-static-world.ts",
    "benchmark:static-world:browser": "tsx tools/benchmark/run-static-world-browser.ts",
    "benchmark:moving-entities": "tsx tools/benchmark/run-moving-entities.ts",
    "validate:skills": "tsx tools/validate/index.ts",
    "check:types": "tsc --noEmit"
